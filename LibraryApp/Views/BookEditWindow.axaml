<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LibraryApp.Views.BookEditWindow"
        Title="Книга" Width="450" Height="360"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleLabel" Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,16" Text="Добавление книги"/>

        <!-- Форма -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Название *" Classes="label"/>
            <TextBox x:Name="TitleBox" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Автор *" Classes="label"/>
            <ComboBox x:Name="AuthorBox" Grid.Row="1" Grid.Column="1" Margin="0,4"
                      HorizontalAlignment="Stretch"
                      DisplayMemberBinding="{Binding FullName}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Жанр *" Classes="label"/>
            <ComboBox x:Name="GenreBox" Grid.Row="2" Grid.Column="1" Margin="0,4"
                      HorizontalAlignment="Stretch"
                      DisplayMemberBinding="{Binding Name}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Год издания" Classes="label"/>
            <TextBox x:Name="YearBox" Grid.Row="3" Grid.Column="1" Margin="0,4"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="ISBN" Classes="label"/>
            <TextBox x:Name="IsbnBox" Grid.Row="4" Grid.Column="1" Margin="0,4"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Количество" Classes="label"/>
            <TextBox x:Name="QuantityBox" Grid.Row="5" Grid.Column="1" Margin="0,4"/>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Classes="secondary"
                    Width="90" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Сохранить" Classes="primary"
                    Width="100" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
